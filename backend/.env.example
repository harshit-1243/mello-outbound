# ─────────────────────────────────────────────────────────────────────────────
# Mello backend configuration — copy to `.env` and fill in your own keys.
#   cp .env.example .env
# The booking engine + dashboard API run with ZERO keys (local SQLite). You only
# need keys for the live voice agent (Cerebras + Sarvam).
# This file is safe to commit; `.env` is git-ignored — never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for local dev/tests (uses SQLite at ./mello_dev.db). For production
# use a Postgres URL. Supabase: Project Settings → Database → Connection string → URI.
# Both postgres:// and postgresql:// are accepted (the app maps them to psycopg v3).
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=

# ── REST API access ───────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API (add your deployed dashboard URL).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional API key. Blank = no auth (fine for local dev). In production set a strong key;
# the dashboard then sends it. Generate one: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── LLM (reasoning) — Cerebras ────────────────────────────────────────────────
# The project stack is Cerebras only. Free key (no card): https://cloud.cerebras.ai
LLM_PROVIDER=cerebras
CEREBRAS_API_KEY=
# zai-glm-4.7 = natural Hinglish (recommended). gpt-oss-120b = English-leaning, strong tool-calling.
CEREBRAS_MODEL=zai-glm-4.7
# "low" keeps each voice turn ~1.5s. CRITICAL for gpt-oss-120b (its default makes turns ~20s).
CEREBRAS_REASONING_EFFORT=low

# ── Speech (STT + TTS) — Sarvam ───────────────────────────────────────────────
# India-native Hinglish stack. Get a key: https://dashboard.sarvam.ai
SARVAM_API_KEY=
# STT: saarika:v2.5 is the streaming ASR that PRESERVES Hinglish.
#      (Do NOT use saaras:* — those translate speech to English.)
STT_PROVIDER=sarvam
SARVAM_STT_MODEL=saarika:v2.5
# TTS: bulbul:v2 = "Standard" model (balanced cost/quality). bulbul:v3 = pricier "Advanced".
TTS_PROVIDER=sarvam
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_VOICE_ID=anushka
SARVAM_LANGUAGE=hi-IN

# ── Free-credit / usage monitor ───────────────────────────────────────────────
# Daily free-tier ceilings used to warn before you run out (0 = don't track a %, alert only on
# hard quota errors). Set to your actual allowances for proactive 80%/100% warnings.
CEREBRAS_DAILY_TOKEN_LIMIT=1000000
SARVAM_DAILY_CHAR_LIMIT=0
SARVAM_DAILY_STT_SECONDS_LIMIT=0

# ── Interim/alternative providers (optional — the project uses Sarvam+Cerebras only) ──
# Only needed if you set STT_PROVIDER/TTS_PROVIDER/LLM_PROVIDER to one of these instead.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_API_KEY=

# ── Telephony (Exotel) — for taking real phone calls (needs Indian-business KYC) ──
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=

# ── WhatsApp BSP (Interakt/Wati) — for booking confirmations ───────────────────
WHATSAPP_PROVIDER=interakt
WHATSAPP_API_KEY=
WHATSAPP_BASE_URL=
